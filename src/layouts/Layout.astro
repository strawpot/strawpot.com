---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'StrawPot — Run an AI company on your laptop',
  description = 'Run an AI company on your laptop. StrawPot launches role-based AI workers—CEO, engineer, QA, reviewer—to complete tasks collaboratively.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta name="theme-color" content="#0a0a0f" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link
      rel="preconnect"
      href="https://api.fontshare.com"
      crossorigin="anonymous"
    />
    <link
      rel="preconnect"
      href="https://cdn.fontshare.com"
      crossorigin="anonymous"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-straw: #e8b931;
    --color-straw-light: #f2d06b;
    --color-straw-dark: #c49a1a;
    --color-green: #4ade80;
    --color-bg-deep: #0a0a0f;
    --color-bg-surface: #12121a;
    --color-bg-elevated: #1a1a25;
    --color-text: #e8e8ed;
    --color-text-muted: #8888a0;
    --color-border: #2a2a3a;

    --font-display: 'Clash Display', sans-serif;
    --font-body: 'Satoshi', sans-serif;
    --font-mono: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;

    --section-padding: 5rem 1.5rem;
    --max-width: 1060px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-body);
    background: var(--color-bg-deep);
    color: var(--color-text);
    line-height: 1.6;
    overflow-x: hidden;
  }

  a {
    color: var(--color-straw);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-straw-light);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  ::selection {
    background: var(--color-straw);
    color: var(--color-bg-deep);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog — StrawPot"
  description="Stories from building an AI company with AI agents. What shipped, what broke, and what surprised us."
>
  <BlogNav />

  <main class="blog-listing">
    <div class="blog-listing-inner">
      <h1>Blog</h1>
      <p class="blog-subtitle">Stories from building an AI company with AI agents.</p>

      {posts.length === 0 ? (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}`} class="post-link">
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-link">Read &rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-listing {
    padding: 8rem 1.5rem 4rem;
  }

  .blog-listing-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-listing h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .blog-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .blog-empty {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    padding: 2rem 0;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 2rem 0;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .post-link:hover {
    color: var(--color-text);
  }

  .post-link:hover h2 {
    color: var(--color-straw);
  }

  .post-link time {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .post-link h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .post-link p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .read-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-straw);
  }

  @media (max-width: 640px) {
    .blog-listing {
      padding: 6rem 1rem 3rem;
    }

    .blog-listing h1 {
      font-size: 2rem;
    }

    .post-link h2 {
      font-size: 1.2rem;
    }
  }
</style>

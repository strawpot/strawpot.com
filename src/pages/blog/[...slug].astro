---
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const words = (post.body ?? '').trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 250));
---

<Layout
  title={`${post.data.title} — StrawPot Blog`}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.ogImage}
  publishedDate={post.data.date}
  author={post.data.author}
>
  <BlogNav />

  <main class="blog-post">
    <article class="post-article">
      <header class="post-header">
        <a href="/blog" class="back-link">&larr; All posts</a>
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span class="post-author">{post.data.author}</span>
          <span class="meta-sep">&middot;</span>
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span class="meta-sep">&middot;</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-link">&larr; All posts</a>
      </footer>
    </article>
  </main>
</Layout>

<style>
  .blog-post {
    padding: 8rem 1.5rem 4rem;
  }

  .post-article {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .back-link:hover {
    color: var(--color-straw);
  }

  .post-header h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-author {
    font-weight: 600;
    color: var(--color-text);
  }

  .meta-sep {
    opacity: 0.4;
  }

  /* Blog post content styling */
  .post-content :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.6rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-straw);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-content :global(pre) {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
  }

  .post-content :global(:not(pre) > code) {
    background: var(--color-bg-elevated);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .post-content :global(img),
  .post-content :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .post-content :global(a) {
    color: var(--color-straw);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--color-straw-light);
  }

  .post-content :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .post-content :global(em) {
    color: var(--color-text-muted);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .blog-post {
      padding: 6rem 1rem 3rem;
    }

    .post-header h1 {
      font-size: 1.8rem;
    }

    .post-meta {
      flex-wrap: wrap;
    }

    .post-content :global(h2) {
      font-size: 1.35rem;
    }
  }
</style>

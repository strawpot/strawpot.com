---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== TOP NAV ===== -->
  <nav class="top-nav">
    <div class="top-nav-inner">
      <a href="/" class="nav-brand">StrawPot</a>
      <div class="nav-links">
        <a href="#how-it-works" class="nav-link nav-link--primary">How It Works</a>
        <a href="https://strawhub.dev" class="nav-link" target="_blank" rel="noopener">StrawHub</a>
        <a href="https://docs.strawpot.com/" class="nav-link" target="_blank" rel="noopener">Docs</a>
        <a href="https://github.com/strawpot/strawpot" class="nav-link" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-badge">Open Source &middot; Early Preview</span>
      <h1 class="hero-title">One engineer. One laptop.<br/>One AI company.</h1>
      <p class="hero-tagline">
        A full AI workforce&mdash;CEO, product manager, engineer, tester, reviewer&mdash;collaborating to ship your product.
      </p>
      <p class="hero-credibility">Built for engineers who want to build products&mdash;not run companies.</p>
      <div class="hero-actions">
        <a href="#quickstart" class="btn btn-primary">Get Started</a>
        <a href="#how-it-works" class="btn btn-ghost">See How It Works</a>
      </div>
      <div class="hero-social-proof">
        <a href="https://github.com/strawpot/strawpot" class="github-stars" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span>Star on GitHub</span>
        </a>
        <span class="social-sep">&middot;</span>
        <span class="social-label">Open Source &middot; MIT License</span>
      </div>
    </div>
  </section>

  <!-- ===== 2. PROBLEM STORY ===== -->
  <section class="problem">
    <div class="problem-inner">
      <h2 class="section-title">Great engineers struggle to run companies</h2>
      <p class="problem-lead">Building technology is only a small part of running a startup.</p>
      <div class="problem-roles">
        <span class="problem-role">Strategy</span>
        <span class="problem-role">Product planning</span>
        <span class="problem-role">Coordination</span>
        <span class="problem-role">Documentation</span>
        <span class="problem-role">Code review</span>
        <span class="problem-role">Testing</span>
        <span class="problem-role">Operations</span>
      </div>
      <p class="problem-pain">Most engineers never trained for these roles.</p>
      <p class="problem-solution">StrawPot lets AI handle those roles so you can focus on building.</p>
    </div>
  </section>

  <!-- ===== 3. KEY INSIGHT ===== -->
  <section class="insight">
    <div class="insight-inner">
      <h2 class="section-title">A company is just roles collaborating</h2>
      <div class="insight-diagram">
        <div class="resolution-window">
          <div class="code-tabs">
            <div class="window-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <span class="resolution-tab">Company Structure</span>
          </div>
          <div class="resolution-content">
<pre class="tree-output"><code> <span class="f">CEO</span>
 ├── <span class="f">Product Manager</span>
 │    └── <span class="s">Analyst</span>
 ├── <span class="f">Engineer</span>
 │    └── <span class="s">Tester</span>
 └── <span class="f">Reviewer</span></code></pre>
          </div>
        </div>
      </div>
      <p class="insight-punchline">StrawPot replaces these roles with AI workers.</p>
    </div>
  </section>

  <!-- ===== 4. HOW IT WORKS ===== -->
  <section id="how-it-works" class="product-intro">
    <h2 class="section-title">Run an AI startup team</h2>
    <p class="section-subtitle">You give a task. StrawPot creates a team of AI workers that collaborate to complete it.</p>

    <div class="see-it-tabs">
      <button class="see-it-tab active" data-example="pm">Product Management</button>
      <button class="see-it-tab" data-example="marketing">Marketing</button>
      <button class="see-it-tab" data-example="research">Research</button>
      <button class="see-it-tab" data-example="sales">Sales</button>
      <button class="see-it-tab" data-example="dev">Engineering</button>
    </div>

    <div class="see-it-example hidden" data-example="sales">
      <div class="see-it-prompt">
        <span class="see-it-label">You:</span> &ldquo;Build a cold outreach sequence for Series A founders.&rdquo;
      </div>
      <div class="delegation-flow">
        <div class="flow-step">
          <span class="flow-role">Sales Lead</span>
          <span class="flow-action">defines target persona &amp; strategy</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Researcher</span>
          <span class="flow-action">builds prospect list &amp; profiles</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Writer</span>
          <span class="flow-action">drafts email sequences</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Editor</span>
          <span class="flow-action">optimizes subject lines &amp; CTAs</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Reviewer</span>
          <span class="flow-action">validates tone &amp; compliance</span>
        </div>
      </div>
    </div>

    <div class="see-it-example hidden" data-example="dev">
      <div class="see-it-prompt">
        <span class="see-it-label">You:</span> &ldquo;Add dark mode to the app.&rdquo;
      </div>
      <div class="delegation-flow">
        <div class="flow-step">
          <span class="flow-role">Team Lead</span>
          <span class="flow-action">breaks down the task, delegates</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Product Manager</span>
          <span class="flow-action">writes the spec</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Engineer</span>
          <span class="flow-action">writes the code</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Tester</span>
          <span class="flow-action">generates tests</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Reviewer</span>
          <span class="flow-action">validates &amp; ships PR</span>
        </div>
      </div>
    </div>

    <div class="see-it-example hidden" data-example="research">
      <div class="see-it-prompt">
        <span class="see-it-label">You:</span> &ldquo;Research competitors and draft a strategy memo.&rdquo;
      </div>
      <div class="delegation-flow">
        <div class="flow-step">
          <span class="flow-role">Research Lead</span>
          <span class="flow-action">breaks down the task, delegates</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Researcher</span>
          <span class="flow-action">gathers data &amp; sources</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Analyst</span>
          <span class="flow-action">identifies patterns</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Writer</span>
          <span class="flow-action">drafts the memo</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Editor</span>
          <span class="flow-action">refines &amp; fact-checks</span>
        </div>
      </div>
    </div>

    <div class="see-it-example" data-example="pm">
      <div class="see-it-prompt">
        <span class="see-it-label">You:</span> &ldquo;Break the Q2 roadmap into tasks and prioritize.&rdquo;
      </div>
      <div class="delegation-flow">
        <div class="flow-step">
          <span class="flow-role">Product Lead</span>
          <span class="flow-action">scopes the roadmap, delegates</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Analyst</span>
          <span class="flow-action">reviews metrics &amp; user feedback</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Product Manager</span>
          <span class="flow-action">writes specs &amp; acceptance criteria</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Writer</span>
          <span class="flow-action">drafts the roadmap document</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Reviewer</span>
          <span class="flow-action">validates priorities &amp; feasibility</span>
        </div>
      </div>
    </div>

    <div class="see-it-example hidden" data-example="marketing">
      <div class="see-it-prompt">
        <span class="see-it-label">You:</span> &ldquo;Write a launch blog post and social media campaign.&rdquo;
      </div>
      <div class="delegation-flow">
        <div class="flow-step">
          <span class="flow-role">Marketing Lead</span>
          <span class="flow-action">plans the campaign, delegates</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Researcher</span>
          <span class="flow-action">analyzes audience &amp; competitors</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Writer</span>
          <span class="flow-action">drafts blog post &amp; copy</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Editor</span>
          <span class="flow-action">refines tone &amp; messaging</span>
        </div>
        <div class="flow-arrow" aria-hidden="true"></div>
        <div class="flow-step">
          <span class="flow-role">Reviewer</span>
          <span class="flow-action">approves &amp; schedules posts</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. CLI / QUICK START ===== -->
  <section id="quickstart" class="quickstart">
    <h2 class="section-title">Start your AI company</h2>
    <div class="code-window">
      <div class="code-tabs">
        <div class="window-dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <span class="resolution-tab">Terminal</span>
      </div>

      <div class="code-block">
        <button
          class="copy-btn"
          data-copy="pip install strawpot
strawpot install role sw-dev-team-lead
strawpot start"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="p">$</span> pip install strawpot
<span class="p">$</span> strawpot install <span class="s">role sw-dev-team-lead</span>
<span class="p">$</span> strawpot start</code></pre>
      </div>
    </div>

    <div class="cli-output">
      <div class="code-window">
        <div class="code-tabs">
          <div class="window-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="resolution-tab">Output</span>
        </div>
        <div class="code-block">
          <pre><code><span class="c">Team Lead</span>    planning roadmap
<span class="c">PM</span>           writing specification
<span class="c">Engineer</span>     implementing feature
<span class="c">Tester</span>       generating tests
<span class="c">Reviewer</span>     approving changes
<span class="s">&#10003; PR shipped</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. USE CASES ===== -->
  <section class="use-cases">
    <h2 class="section-title">What can an AI company do?</h2>
    <div class="use-cases-grid">
      <div class="use-case-card">
        <h3>Build software</h3>
        <p class="use-case-example">&ldquo;Build a todo app with login.&rdquo;</p>
        <p class="use-case-desc">Team lead delegates to PM, engineer, tester, and reviewer&mdash;ships a PR.</p>
      </div>
      <div class="use-case-card">
        <h3>Research</h3>
        <p class="use-case-example">&ldquo;Analyze competitors in robotics.&rdquo;</p>
        <p class="use-case-desc">Researcher gathers data, analyst finds patterns, writer drafts the report.</p>
      </div>
      <div class="use-case-card">
        <h3>Operations</h3>
        <p class="use-case-example">&ldquo;Prepare investor update report.&rdquo;</p>
        <p class="use-case-desc">Writer pulls metrics, analyst interprets trends, editor polishes output.</p>
      </div>
      <div class="use-case-card">
        <h3>Project management</h3>
        <p class="use-case-example">&ldquo;Break roadmap into tasks.&rdquo;</p>
        <p class="use-case-desc">PM structures milestones, team lead assigns to roles, tracks progress.</p>
      </div>
    </div>
  </section>

  <!-- ===== 7. WHY ENGINEERS LOVE THIS ===== -->
  <section class="why-engineers">
    <h2 class="section-title">Built for engineers who hate running companies</h2>
    <div class="why-grid">
      <div class="why-item">
        <span class="why-icon">&#10005;</span>
        <span class="why-text">No meetings</span>
      </div>
      <div class="why-item">
        <span class="why-icon">&#10005;</span>
        <span class="why-text">No management overhead</span>
      </div>
      <div class="why-item">
        <span class="why-icon">&#10005;</span>
        <span class="why-text">No coordination burden</span>
      </div>
      <div class="why-item why-item--positive">
        <span class="why-icon why-icon--yes">&#10003;</span>
        <span class="why-text">Focus on building</span>
      </div>
    </div>
    <p class="why-punchline">One engineer can run a team of AI workers.</p>
  </section>

  <!-- ===== 8. ARCHITECTURE ===== -->
  <section class="architecture">
    <h2 class="section-title">How StrawPot Works</h2>
    <div class="arch-grid">
      <div class="arch-item">
        <h3>Role-based AI agents</h3>
        <p>Each role is a Markdown file with skills and dependencies. No Python. No boilerplate.</p>
      </div>
      <div class="arch-item">
        <h3>Open skill registry</h3>
        <p>StrawHub is npm for AI roles. Install community roles or publish your own.</p>
      </div>
      <div class="arch-item">
        <h3>Any agent runtime</h3>
        <p>Claude Code, Codex, Gemini, or your own. Assign different runtimes per role.</p>
      </div>
      <div class="arch-item">
        <h3>Local execution</h3>
        <p>Everything runs on your machine. Your code never leaves your laptop.</p>
      </div>
      <div class="arch-item">
        <h3>Memory &amp; context</h3>
        <p>Agents share knowledge across sessions. Your AI company learns over time.</p>
      </div>
      <div class="arch-item">
        <h3>Agent orchestration</h3>
        <p>Automatic delegation, isolation, and merge strategies. You give the task; StrawPot runs the team.</p>
      </div>
    </div>
  </section>

  <!-- ===== 9. VISION ===== -->
  <section class="vision">
    <div class="vision-inner">
      <h2 class="section-title">The future company</h2>
      <p class="vision-text">
        The future company may look different.<br/>
        One human. Hundreds of AI workers.
      </p>
      <p class="vision-punchline">StrawPot is an operating system for that future.</p>
    </div>
  </section>

  <!-- ===== 10. OPEN SOURCE ===== -->
  <section class="open-source">
    <h2 class="section-title">Open source &amp; community driven</h2>
    <div class="os-links">
      <a href="https://github.com/strawpot/strawpot" class="hero-link hero-link--github" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="hero-link-label">GitHub</span>
        <span class="hero-link-sub">View source &amp; contribute</span>
      </a>
      <a href="https://docs.strawpot.com/" class="hero-link hero-link--docs" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="hero-link-label">Docs</span>
        <span class="hero-link-sub">Read the documentation</span>
      </a>
      <a href="https://strawhub.dev" class="hero-link hero-link--strawhub" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <span class="hero-link-label">StrawHub</span>
        <span class="hero-link-sub">Browse roles &amp; skills</span>
      </a>
      <a href="https://discord.gg/buEbvEMC" class="hero-link hero-link--discord" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
        <span class="hero-link-label">Discord</span>
        <span class="hero-link-sub">Join the community</span>
      </a>
    </div>
  </section>

  <!-- ===== 11. FINAL CTA ===== -->
  <section class="final-cta">
    <h2 class="section-title">Start your AI company</h2>
    <div class="hero-install" style="animation:none;">
      <code class="hero-cmd">
        <span class="p">$</span> pip install strawpot
      </code>
      <button
        class="copy-btn hero-copy"
        data-copy="pip install strawpot"
        aria-label="Copy install command"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>

  .step-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .step-card p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }


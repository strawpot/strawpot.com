    border-radius: 12px;
    display: inline-block;
  }

  .see-it-label {
    color: var(--color-straw);
    font-weight: 600;
    margin-right: 0.5rem;
  }

  /* ===== DELEGATION FLOW (vertical) ===== */
  .delegation-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 360px;
    margin: 0 auto;
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1rem 2rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    width: 100%;
    transition: all 0.25s;
  }

  .flow-step:first-child {
    border-color: var(--color-straw);
    border-width: 2px;
  }

  .flow-step:hover {
    border-color: rgba(232, 185, 49, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .flow-role {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-straw);
  }

  .flow-action {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .flow-arrow {
    width: 1px;
    height: 1.5rem;
    background: var(--color-border);
    position: relative;
  }

  .flow-arrow::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid var(--color-border);
  }

  /* ===== 5. QUICK START ===== */
  .quickstart {
    padding: 6rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }

  .quickstart::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);
  }

  .cli-output {
    margin-top: 1.5rem;
  }

  .code-window {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .code-tabs {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }

  .window-dots {
    display: flex;
    gap: 6px;
    padding: 0 1rem;
  }

  .window-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
  }

  .window-dots span:first-child {
    background: #ff5f57;
  }

  .window-dots span:nth-child(2) {
    background: #febc2e;
  }

  .window-dots span:nth-child(3) {
    background: #28c840;
  }

  .code-block {
    position: relative;
    padding: 1.5rem;
  }

  .code-block.hidden {
    display: none;
  }

  .code-block pre {
    margin: 0;
    overflow-x: auto;
  }

  .code-block code {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .code-block .c {
    color: var(--color-text-muted);
  }

  .code-block .p {
    color: var(--color-green);
    user-select: none;
  }

  .code-block .f {
    color: var(--color-straw);
  }

  .code-block .s {
    color: var(--color-green);
  }

  .resolution-window {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .resolution-tab {

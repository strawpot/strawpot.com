  .copy-btn.copied .check-icon {
    display: block;
    color: var(--color-green);
  }

  .copy-btn.copied svg:first-child {
    display: none;
  }

  /* ===== 6. USE CASES ===== */
  .use-cases {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);

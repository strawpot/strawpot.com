    padding: 1.5rem 2rem;
    text-align: left;
  }

  .tree-output {
    margin: 0;
    overflow-x: auto;
  }

  .tree-output code {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .copy-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.4rem;
    border-radius: 6px;

---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== TOP NAV ===== -->
  <nav class="top-nav">
    <div class="top-nav-inner">
      <a href="/" class="nav-brand">StrawPot</a>
      <div class="nav-links">
        <a href="#how-it-works" class="nav-link nav-link--primary">How It Works</a>
        <a href="https://strawhub.dev" class="nav-link" target="_blank" rel="noopener">StrawHub</a>
        <a href="https://docs.strawpot.com/" class="nav-link" target="_blank" rel="noopener">Docs</a>
        <a href="https://github.com/strawpot/strawpot" class="nav-link" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-badge">Open Source &middot; Early Preview</span>

      <!-- Demo first: the first thing visitors see -->
      <div class="hero-demo">
        <img src="/demo.png" alt="StrawPot: one task, agents compose roles and execute" class="demo-gif" loading="eager" />
      </div>

      <h1 class="hero-title">One Engineer. One Laptop. One AI Company.</h1>
      <p class="hero-contrast">Run an AI company locally: CEO, engineer, QA, and reviewer, all collaborating to ship your product.</p>
      <p class="hero-tagline">
        You direct the agents. They coordinate, delegate, and deliver. The human stays in the loop.
      </p>
      <p class="hero-credibility">Zero to AI team in 5 minutes. Outputs vary. Infrastructure does not.</p>
      <div class="hero-actions">
        <a href="#quickstart" class="btn btn-primary">Get Started</a>
        <a href="#how-it-works" class="btn btn-ghost">See How It Works</a>
      </div>
      <div class="hero-social-proof">
        <a href="https://github.com/strawpot/strawpot" class="github-stars" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span class="star-label">Star on GitHub</span><span class="star-count" id="star-count"></span>
        </a>
        <span class="social-sep">&middot;</span>
        <span class="social-label">Open Source &middot; MIT License</span>
      </div>
    </div>
  </section>

  <!-- ===== 2. PROOF: WHAT IT PRODUCES ===== -->
  <section class="proof">
    <h2 class="section-title">How agents coordinate</h2>
    <p class="section-subtitle">&ldquo;Add dark mode to the app&rdquo;</p>
    <div class="proof-grid">
      <div class="proof-card">
        <h3>ai-ceo</h3>
        <p class="proof-meta">Plans the rollout, delegates to implementer and reviewer</p>
      </div>
      <div class="proof-card">
        <h3>implementer</h3>
        <p class="proof-meta">Writes code in an isolated git worktree</p>
      </div>
      <div class="proof-card">
        <h3>reviewer</h3>
        <p class="proof-meta">Checks changes, runs tests, approves</p>
      </div>
    </div>
    <p class="proof-caveat">Structured artifacts land in your workspace. Outputs vary depending on model and task.</p>
  </section>

  <!-- ===== WORKFLOWS ===== -->
  <section class="workflows">
    <h2 class="section-title">What you can do today</h2>
    <div class="workflows-grid">
      <div class="workflow-card">
        <h3>Triage and plan GitHub issues</h3>
        <p class="workflow-desc">Automatically triage and plan GitHub issues: prioritization, decomposition, delegation.</p>
      </div>
      <div class="workflow-card">
        <h3>Turn an idea into a PR</h3>
        <p class="workflow-desc">Automatically go from idea to shipped code: ideation, approval, implementation, and review.</p>
      </div>
      <div class="workflow-card">
        <h3>Create and refine roles automatically</h3>
        <p class="workflow-desc">Define new roles, test them through evaluation and iteration, and publish to StrawHub for reuse.</p>
      </div>
    </div>
    <p class="workflows-caveat">Workflows improve over time as roles are reused and refined.</p>
  </section>

  <!-- ===== WHY THIS EXISTS ===== -->
  <section class="why-exists">
    <h2 class="section-title">Why this exists</h2>
    <p class="why-text">Most AI agent systems stop at orchestration. They run prompts. They don't evolve behavior, share reusable roles, or build on each other.</p>
    <p class="why-text">StrawPot makes AI workers composable, reusable, and evolvable. <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a> distributes what works. The system improves as roles are shared and refined.</p>
    <p class="why-ambition">The infrastructure is ready. The next problem is how agent behaviors evolve and improve. That's what we're building toward.</p>
  </section>

  <!-- ===== HUMAN-DIRECTED ===== -->
  <section class="human-directed">
    <h2 class="section-title">Human-directed, not human-replaced</h2>
    <p class="why-text">StrawPot agents are powerful, but they answer to you. You set the direction, define the roles, approve the plans, and stay in the loop.</p>
    <p class="why-text">This is not about replacing engineers with AI. It is about giving one engineer the leverage of an entire team, while that engineer remains the decision-maker.</p>
    <p class="why-ambition">Competitors race toward full autonomy. StrawPot takes the opposite position: the human is always the captain.</p>
  </section>

  <!-- ===== 3. HOW IT WORKS ===== -->
  <section id="how-it-works" class="how-steps">
    <h2 class="section-title">How it works</h2>
    <div class="steps-grid">
      <div class="step-card">
        <span class="step-number">1</span>
        <h3>Give it a goal</h3>
        <p>&ldquo;Add dark mode to the app.&rdquo;</p>
      </div>
      <div class="step-card">
        <span class="step-number">2</span>
        <h3>Roles collaborate</h3>
        <p>CEO plans. PM specs. Engineer builds. Tester validates.</p>
      </div>
      <div class="step-card">
        <span class="step-number">3</span>
        <h3>Artifacts land</h3>
        <p>Plan, code, tests, and content, all in your local workspace.</p>
      </div>
    </div>
  </section>

  <!-- ===== 5. CLI / QUICK START ===== -->
  <section id="quickstart" class="quickstart">
    <h2 class="section-title">Get started locally</h2>
    <div class="code-window">
      <div class="code-tabs">
        <div class="window-dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <span class="resolution-tab">Terminal</span>
      </div>

      <div class="code-block">
        <button
          class="copy-btn"
          data-copy="pip install strawpot
strawpot gui"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="p">$</span> pip install strawpot
<span class="p">$</span> strawpot gui</code></pre>
      </div>
    </div>

    <div class="cli-output">
      <div class="code-window">
        <div class="code-tabs">
          <div class="window-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="resolution-tab">Output</span>
        </div>
        <div class="code-block">
          <pre><code><span class="s">&#10003;</span> Plan generated by ai-ceo
<span class="s">&#10003;</span> Implementation delegated to implementer
<span class="s">&#10003;</span> Code written in isolated worktree
<span class="s">&#10003;</span> Review completed by code-reviewer
<span class="s">&#10003;</span> Tests passing

<span class="s">&#10003; Done: 4 artifacts in ./output</span></code></pre>
        </div>
      </div>
    </div>

    <div class="cli-output">
      <div class="code-window">
        <div class="code-tabs">
          <div class="window-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="resolution-tab">StrawHub</span>
        </div>
        <div class="code-block">
          <pre><code><span class="c"># Install from the community</span>
<span class="p">$</span> strawhub install role code-reviewer

<span class="c"># Publish what you've built</span>
<span class="p">$</span> strawhub publish skill my-custom-skill</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 4. UNDER THE HOOD ===== -->
  <section class="architecture">
    <h2 class="section-title">Under the hood</h2>
    <div class="arch-grid">
      <div class="arch-item">
        <h3>Recursive delegation</h3>
        <p>Agents spawn sub-agents concurrently with policy control, depth limits, and full call tree tracing.</p>
      </div>
      <div class="arch-item">
        <h3>Git worktree isolation</h3>
        <p>Every session gets its own branch. Concurrent sessions, crash recovery, configurable merge strategies.</p>
      </div>
      <div class="arch-item">
        <h3>Persistent memory</h3>
        <p>Three-tier context cards that agents read and write across sessions. Pluggable providers.</p>
      </div>
      <div class="arch-item">
        <h3>Any agent runtime</h3>
        <p>Claude Code, Codex, Gemini, or your own. Two commands to add a new runtime. Mixed per role.</p>
      </div>
      <div class="arch-item">
        <h3>Roles as Markdown</h3>
        <p>No Python, no orchestration code. Roles and skills are Markdown files you can read, version, and share.</p>
      </div>
      <div class="arch-item">
        <h3>Structured tracing</h3>
        <p>Every delegation, spawn, and memory access recorded to JSONL. Content-addressed artifacts. Full reconstruction.</p>
      </div>
    </div>
  </section>

  <!-- ===== STATUS ===== -->
  <section class="status-section">
    <h2 class="section-title">Status</h2>
    <div class="status-grid">
      <div class="status-col">
        <h3>Production-grade infrastructure</h3>
        <ul>
          <li>Role-based coordination</li>
          <li>Multi-agent delegation</li>
          <li>Memory, tracing, and isolation</li>
        </ul>
      </div>
      <div class="status-col">
        <h3>AI outputs</h3>
        <ul>
          <li>Still evolving</li>
          <li>May be inconsistent depending on task and model</li>
        </ul>
      </div>
    </div>
    <p class="status-text">The system is solid. The intelligence layer is still maturing.</p>
  </section>

  <!-- ===== 10. OPEN SOURCE ===== -->
  <section class="open-source">
    <h2 class="section-title">Open source &amp; community driven</h2>
    <div class="os-links">
      <a href="https://github.com/strawpot/strawpot" class="hero-link hero-link--github" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="hero-link-label">GitHub</span>
        <span class="hero-link-sub">View source &amp; contribute</span>
      </a>
      <a href="https://docs.strawpot.com/" class="hero-link hero-link--docs" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="hero-link-label">Docs</span>
        <span class="hero-link-sub">Read the documentation</span>
      </a>
      <a href="https://strawhub.dev" class="hero-link hero-link--strawhub" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <span class="hero-link-label">StrawHub</span>
        <span class="hero-link-sub">Install &amp; publish roles, skills, and more</span>
      </a>
      <a href="https://discord.gg/6RMpzuKrRd" class="hero-link hero-link--discord" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
        <span class="hero-link-label">Discord</span>
        <span class="hero-link-sub">Join the community</span>
      </a>
    </div>
  </section>

  <!-- ===== 11. FINAL CTA ===== -->
  <section class="final-cta">
    <p class="builder-trigger">If you're building agent systems, this is the layer you extend.</p>
    <h2 class="section-title">Get started locally</h2>
    <div class="hero-install" style="animation:none;">
      <code class="hero-cmd">
        <span class="p">$</span> pip install strawpot
      </code>
      <button
        class="copy-btn hero-copy"
        data-copy="pip install strawpot"
        aria-label="Copy install command"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
    <div class="hero-actions" style="animation:none;">
      <a href="https://docs.strawpot.com/" class="btn btn-primary" target="_blank" rel="noopener">Read Docs</a>
      <a href="https://github.com/strawpot/strawpot" class="btn btn-ghost" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="footer-subscribe">
      <p class="footer-subscribe-label">Get updates. No spam.</p>
      <form
        class="subscribe-form"
        id="subscribe-form"
        action="https://buttondown.com/api/emails/embed-subscribe/strawpot"
        method="post"
        target="bd-iframe"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          aria-label="Email address"
        />
        <button type="submit" class="btn btn-primary btn-sm">Subscribe</button>
      </form>
      <iframe name="bd-iframe" id="bd-iframe" style="display:none" aria-hidden="true"></iframe>
      <p class="subscribe-msg" id="subscribe-msg"></p>
    </div>
    <nav class="footer-links">
      <a href="#how-it-works">How It Works</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://discord.gg/6RMpzuKrRd" target="_blank" rel="noopener">Discord</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/strawpot/strawpot" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://pypi.org/project/strawpot/" target="_blank" rel="noopener">PyPI</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/strawpot/strawpot/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
    </nav>
    <p class="footer-brand">One engineer. One laptop. One AI company.</p>
    <p class="footer-credit">Built by the StrawPot contributors.</p>
  </footer>
</Layout>

<style>
  /* ===== TOP NAV ===== */
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }

  .top-nav--scrolled {
    border-bottom-color: var(--color-border);
  }

  .top-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link--primary {
    color: var(--color-straw);
  }

  .nav-link--primary:hover {
    color: var(--color-straw-light);
  }

  /* ===== HERO ===== */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: 6rem 1.5rem 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    background: radial-gradient(
      ellipse at center,
      rgba(232, 185, 49, 0.12) 0%,
      rgba(232, 185, 49, 0.04) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border) 50%,
      transparent 100%
    );
  }

  .hero-inner {
    max-width: var(--max-width);
    position: relative;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0s both;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #fff 0%, var(--color-straw-light) 30%, var(--color-straw) 70%, var(--color-straw-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 620px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  .hero-contrast {
    font-size: 1.05rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 1rem;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  .hero-credibility {
    font-size: 0.95rem;
    color: var(--color-straw);
    font-weight: 500;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }

  .hero-social-proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    animation: fadeInUp 0.6s ease-out 0.5s both;
  }

  .github-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .github-stars:hover {
    border-color: var(--color-straw);
    color: var(--color-straw);
  }

  .github-stars svg {
    flex-shrink: 0;
  }

  .star-count {
    padding-left: 0.4rem;
    border-left: 1px solid var(--color-border);
    margin-left: 0.2rem;
    font-variant-numeric: tabular-nums;
  }

  .star-count:empty {
    display: none;
  }

  .social-sep {
    color: var(--color-border);
  }

  .social-label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-straw);
    color: var(--color-bg-deep);
  }

  .btn-primary:hover {
    background: var(--color-straw-light);
    color: var(--color-bg-deep);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(232, 185, 49, 0.3);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  /* ===== SECTION COMMON ===== */
  .section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    text-align: center;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .section-title + .section-subtitle {
    margin-top: -0.25rem;
  }

  /* ===== DEMO GIF ===== */
  .demo-section {
    padding: 0 1.5rem 3rem;
    margin-top: -2rem;
    position: relative;
    z-index: 1;
  }

  .demo-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .demo-gif {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 185, 49, 0.08);
  }

  /* ===== HERO DEMO (inline in hero) ===== */
  .hero-demo {
    max-width: 960px;
    margin: 0 auto 2.5rem;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .hero-demo .demo-gif {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 185, 49, 0.08);
  }

  /* ===== 2. PROOF SECTION ===== */
  .proof {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .proof::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    text-align: left;
  }

  .proof-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2.25rem;
    transition: all 0.25s;
  }

  .proof-card:hover {
    transform: translateY(-2px);
    border-color: rgba(232, 185, 49, 0.2);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .proof-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .proof-meta {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-straw);
    line-height: 1.5;
  }

  /* ===== 3. HOW STEPS ===== */
  .how-steps {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .how-steps::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);

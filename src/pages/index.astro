---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== TOP NAV ===== -->
  <nav class="top-nav">
    <div class="top-nav-inner">
      <a href="/" class="nav-brand">StrawPot</a>
      <div class="nav-links">
        <a href="#workforce" class="nav-link nav-link--primary">Roles</a>
        <a href="#workforce" class="nav-link">Skills</a>
        <a href="https://strawhub.dev" class="nav-link" target="_blank" rel="noopener">StrawHub</a>
        <a href="https://docs.strawpot.com/" class="nav-link" target="_blank" rel="noopener">Docs</a>
        <a href="https://github.com/strawpot/strawpot" class="nav-link" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-badge">Open Source &middot; v0.1 Early Preview</span>
      <h1 class="hero-title">StrawPot</h1>
      <p class="hero-tagline">AI agents work better in teams.</p>
      <p class="hero-subtitle">
        Install roles like Team&nbsp;Lead, Implementer, or Analyst.
        StrawPot automatically resolves the skills needed for the job and launches the team.
      </p>
      <div class="hero-install">
        <code class="hero-cmd">
          <span class="p">$</span> pip install strawpot
        </code>
        <button
          class="copy-btn hero-copy"
          data-copy="pip install strawpot"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
      <div class="hero-actions">
        <a href="#quickstart" class="btn btn-primary">Run the 60-second demo</a>
        <a
          href="https://strawhub.dev"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener"
        >
          Browse roles on StrawHub
        </a>
      </div>
      <div class="hero-links">
        <a href="https://discord.gg/buEbvEMC" class="hero-link hero-link--discord" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
          <span class="hero-link-label">Discord</span>
          <span class="hero-link-sub">Join the community</span>
        </a>
        <a href="https://docs.strawpot.com/" class="hero-link hero-link--docs" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <span class="hero-link-label">Documentation</span>
          <span class="hero-link-sub">Read the documentation</span>
        </a>
        <a href="https://github.com/strawpot/strawpot" class="hero-link hero-link--github" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span class="hero-link-label">GitHub</span>
          <span class="hero-link-sub">View the source</span>
        </a>
        <a href="https://strawhub.dev" class="hero-link hero-link--strawhub" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span class="hero-link-label">StrawHub</span>
          <span class="hero-link-sub">Install a role, get its skills</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== THE WORKFORCE MODEL ===== -->
  <section id="workforce" class="workforce-model">
    <h2 class="section-title">The Workforce Model</h2>
    <p class="section-subtitle">Skills are abilities. Roles are jobs. Teams are roles collaborating.</p>
    <div class="workforce-grid">
      <div class="workforce-card">
        <h3>Skills</h3>
        <p class="workforce-def">Atomic capabilities such as writing code, searching documents, or running tests.</p>
      </div>
      <div class="workforce-card workforce-card--role">
        <h3>Roles</h3>
        <p class="workforce-def">Job definitions that automatically load the skills needed for the work.</p>
      </div>
      <div class="workforce-card workforce-card--team">
        <h3>Teams</h3>
        <p class="workforce-def">Roles collaborating to complete tasks.</p>
      </div>
    </div>
    <div class="role-tree">
      <div class="resolution-window">
        <div class="code-tabs">
          <div class="window-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="resolution-tab">strawpot resolve role implementer</span>
        </div>
        <div class="resolution-content">
          <pre class="tree-output"><code><span class="f">Role: implementer</span>
 ├─ <span class="s">git-workflow</span>
 ├─ <span class="s">python-dev</span>
 ├─ <span class="s">run-tests</span>
 └─ <span class="s">code-review</span></code></pre>
        </div>
      </div>
      <p class="tree-caption">Install a role. StrawPot resolves the skills automatically.</p>
    </div>
  </section>

  <!-- ===== QUICK START ===== -->
  <section id="quickstart" class="quickstart">
    <h2 class="section-title">Quick Start</h2>
    <div class="code-window">
      <div class="code-tabs">
        <div class="window-dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <button class="code-tab active" data-mode="install">Team Lead</button>
        <button class="code-tab" data-mode="reviewer">Reviewer</button>
        <button class="code-tab" data-mode="source">From Source</button>
      </div>

      <div class="code-block" data-mode="install">
        <button
          class="copy-btn"
          data-copy="pip install strawpot
strawpot install role team-lead
strawpot start --role team-lead"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="c"># Install StrawPot</span>
<span class="p">$</span> pip install strawpot

<span class="c"># Install a role from StrawHub</span>
<span class="p">$</span> strawpot install <span class="s">role team-lead</span>

<span class="c"># Start a session with the role</span>
<span class="p">$</span> strawpot start <span class="f">--role</span> team-lead</code></pre>
      </div>

      <div class="code-block hidden" data-mode="reviewer">
        <button
          class="copy-btn"
          data-copy="strawpot install role reviewer
strawpot start --role reviewer"
          aria-label="Copy reviewer commands"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="c"># Install the reviewer role</span>
<span class="p">$</span> strawpot install <span class="s">role reviewer</span>

<span class="c"># Run review on the current repo</span>
<span class="p">$</span> strawpot start <span class="f">--role</span> reviewer</code></pre>
      </div>

      <div class="code-block hidden" data-mode="source">
        <button
          class="copy-btn"
          data-copy="git clone https://github.com/strawpot/strawpot && cd strawpot/cli && pip install -e '.[dev]'"
          aria-label="Copy source install commands"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="c"># Clone and install from source</span>
<span class="p">$</span> git clone https://github.com/strawpot/strawpot
<span class="p">$</span> <span class="f">cd</span> strawpot/cli
<span class="p">$</span> pip install <span class="f">-e</span> <span class="s">".[dev]"</span></code></pre>
      </div>
    </div>
  </section>

  <!-- ===== EXAMPLE TEAMS ===== -->
  <section class="example-team">
    <h2 class="section-title">Example Teams</h2>
    <p class="section-subtitle">Roles define team composition. StrawPot handles delegation.</p>
    <div class="team-grid">
      <div class="team-tree-card">
        <h3>Engineering</h3>
        <pre class="tree-output"><code><span class="f">team-lead</span>
 ├─ product-manager
 ├─ implementer
 ├─ tester
 └─ reviewer</code></pre>
      </div>
      <div class="team-tree-card">
        <h3>Research</h3>
        <pre class="tree-output"><code><span class="f">strategist</span>
 ├─ analyst
 ├─ writer
 └─ reviewer</code></pre>
      </div>
      <div class="team-tree-card">
        <h3>Product</h3>
        <pre class="tree-output"><code><span class="f">product-manager</span>
 ├─ analyst
 └─ implementer</code></pre>
      </div>
    </div>
    <div class="team-workflow">
      <h3>Example workflow</h3>
      <p class="workflow-prompt"><span class="c">User request:</span> Add dark mode to the app.</p>
      <div class="workflow-steps">
        <div class="workflow-step">
          <span class="workflow-role">product-manager</span>
          <span class="workflow-action">writes the spec</span>
        </div>
        <div class="workflow-step">
          <span class="workflow-role">implementer</span>
          <span class="workflow-action">writes the code</span>
        </div>
        <div class="workflow-step">
          <span class="workflow-role">tester</span>
          <span class="workflow-action">generates tests</span>
        </div>
        <div class="workflow-step">
          <span class="workflow-role">reviewer</span>
          <span class="workflow-action">validates changes</span>
        </div>
        <div class="workflow-step workflow-step--human">
          <span class="workflow-role">human</span>
          <span class="workflow-action">approves merge</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ROLE REGISTRY ===== -->
  <section id="registry" class="role-registry">
    <h2 class="section-title">StrawHub Role Registry</h2>
    <p class="section-subtitle">StrawHub is the registry of roles for AI workers. Installing a role automatically installs the skills required for that job.</p>
    <div class="registry-grid">
      <div class="role-card">
        <h3>Implementer</h3>
        <div class="role-skills">
          <span class="skill-chip">git-workflow</span>
          <span class="skill-chip">python-dev</span>
          <span class="skill-chip">run-tests</span>
          <span class="skill-chip">code-review</span>
        </div>
        <code class="role-install"><span class="p">$</span> strawpot install <span class="s">role implementer</span></code>
      </div>
      <div class="role-card">
        <h3>Reviewer</h3>
        <div class="role-skills">
          <span class="skill-chip">code-review</span>
          <span class="skill-chip">diff-analysis</span>
          <span class="skill-chip">lint-gates</span>
        </div>
        <code class="role-install"><span class="p">$</span> strawpot install <span class="s">role reviewer</span></code>
      </div>
      <div class="role-card">
        <h3>Team Lead</h3>
        <div class="role-skills">
          <span class="skill-chip">task-breakdown</span>
          <span class="skill-chip">delegation</span>
          <span class="skill-chip">merge-gating</span>
        </div>
        <code class="role-install"><span class="p">$</span> strawpot install <span class="s">role team-lead</span></code>
      </div>
    </div>
    <div class="registry-actions">
      <a href="https://strawhub.dev" class="btn btn-primary" target="_blank" rel="noopener">Browse role index</a>
      <a href="https://docs.strawpot.com/strawhub/publishing/guide" class="btn btn-ghost" target="_blank" rel="noopener">Publish a role</a>
    </div>
  </section>

  <!-- ===== SYSTEM PROPERTIES ===== -->
  <section class="features">
    <h2 class="section-title">System Properties</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Safe Execution</h3>
        <p>
          Agents run in isolated sessions&mdash;git worktrees, Docker, or custom
          environments. Your main workspace stays untouched.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
        <h3>Human Approval</h3>
        <p>
          Critical operations require explicit confirmation. Changes only merge
          when tests pass and reviews are approved.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5"></polyline>
            <line x1="12" y1="19" x2="20" y2="19"></line>
          </svg>
        </div>
        <h3>Agent Compatibility</h3>
        <p>
          Works with Claude&nbsp;Code, Codex, Gemini, or your own runtime.
          Mix and match per role.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>
        <h3>Local-First</h3>
        <p>
          Runs locally with minimal setup. No cloud dependency, no data
          leaving your machine.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== SUBSCRIBE ===== -->
  <section class="subscribe">
    <h2 class="section-title">Stay in the loop</h2>
    <p class="subscribe-desc">
      Get updates on new releases, features, and community highlights. No spam.
    </p>
    <form
      class="subscribe-form"
      id="subscribe-form"
      action="https://buttondown.com/api/emails/embed-subscribe/strawpot"
      method="post"
      target="bd-iframe"
    >
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        aria-label="Email address"
      />
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>
    <iframe name="bd-iframe" id="bd-iframe" style="display:none" aria-hidden="true"></iframe>
    <p class="subscribe-msg" id="subscribe-msg"></p>
    <p class="subscribe-note">
      Powered by <a href="https://buttondown.com" target="_blank" rel="noopener">Buttondown</a>
    </p>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <nav class="footer-links">
      <a href="#roles">Roles</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://discord.gg/buEbvEMC" target="_blank" rel="noopener">Discord</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/strawpot/strawpot" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://pypi.org/project/strawpot/" target="_blank" rel="noopener">PyPI</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/strawpot/strawpot/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
    </nav>
    <p class="footer-credit">Built by the StrawPot contributors.</p>
  </footer>
</Layout>

<style>
  /* ===== TOP NAV ===== */
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }

  .top-nav--scrolled {
    border-bottom-color: var(--color-border);
  }

  .top-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link--primary {
    color: var(--color-straw);
  }

  .nav-link--primary:hover {
    color: var(--color-straw-light);
  }

  /* ===== HERO ===== */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 6rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    background: radial-gradient(
      ellipse at center,
      rgba(232, 185, 49, 0.12) 0%,
      rgba(232, 185, 49, 0.04) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::after {

---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-badge">Open Source &middot; v0.1 Early Preview</span>
      <h1 class="hero-title">StrawPot</h1>
      <p class="hero-tagline">AI teams, one command away.</p>
      <p class="hero-subtitle">
        An open-source CLI that spins up AI agent teams&mdash;they split work,
        share context, and merge results, each in its own isolated workspace.
        Run one team or many across projects with Claude&nbsp;Code, Codex,
        OpenHands, and reusable components from
        <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a>.
      </p>
      <div class="hero-install">
        <code class="hero-cmd">
          <span class="p">$</span> pip install strawpot
        </code>
        <button
          class="copy-btn hero-copy"
          data-copy="pip install strawpot"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
      <div class="hero-actions">
        <a href="#quickstart" class="btn btn-primary">Get Started</a>
        <a
          href="https://github.com/strawpot/strawpot"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
      <div class="hero-links">
        <a href="https://discord.gg/buEbvEMC" class="hero-link hero-link--discord" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg>
          <span class="hero-link-label">Discord</span>
          <span class="hero-link-sub">Join the community</span>
        </a>
        <a href="https://github.com/strawpot/strawpot" class="hero-link hero-link--github" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span class="hero-link-label">GitHub</span>
          <span class="hero-link-sub">View the source</span>
        </a>
        <a href="https://strawhub.dev" class="hero-link hero-link--strawhub" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span class="hero-link-label">StrawHub</span>
          <span class="hero-link-sub">Browse skills & roles</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== QUICK START ===== -->
  <section id="quickstart" class="quickstart">
    <h2 class="section-title">Quick Start</h2>
    <div class="code-window">
      <div class="code-tabs">
        <div class="window-dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <button class="code-tab active" data-mode="install">Install</button>
        <button class="code-tab" data-mode="source">From Source</button>
      </div>

      <div class="code-block" data-mode="install">
        <button
          class="copy-btn"
          data-copy="pip install strawpot"
          aria-label="Copy install command"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="c"># Install StrawPot</span>
<span class="p">$</span> pip install strawpot

<span class="c"># Start a session</span>
<span class="p">$</span> strawpot start <span class="f">--role</span> team-lead</code></pre>
      </div>

      <div class="code-block hidden" data-mode="source">
        <button
          class="copy-btn"
          data-copy="git clone https://github.com/strawpot/strawpot && cd strawpot/cli && pip install -e '.[dev]'"
          aria-label="Copy source install commands"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <pre><code><span class="c"># Clone and install from source</span>
<span class="p">$</span> git clone https://github.com/strawpot/strawpot
<span class="p">$</span> <span class="f">cd</span> strawpot/cli
<span class="p">$</span> pip install <span class="f">-e</span> <span class="s">".[dev]"</span></code></pre>
      </div>
    </div>
  </section>

  <!-- ===== FEATURES ===== -->
  <section class="features">
    <h2 class="section-title">What It Does</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h3>Isolated Sessions</h3>
        <p>
          Each session runs in its own sandbox&mdash;git worktree, Docker, or
          a custom environment. Agents work freely without touching your
          main workspace until you&rsquo;re ready to merge results.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="5" r="3"></circle>
            <circle cx="5" cy="19" r="3"></circle>
            <circle cx="19" cy="19" r="3"></circle>
            <line x1="12" y1="8" x2="5" y2="16"></line>
            <line x1="12" y1="8" x2="19" y2="16"></line>
          </svg>
        </div>
        <h3>Multi-Agent Delegation</h3>
        <p>
          A lead agent breaks work into tasks, then StrawPot spawns
          specialists&mdash;researchers, writers, coders, reviewers&mdash;all
          coordinated automatically across any workflow.
        </p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5"></polyline>
            <line x1="12" y1="19" x2="20" y2="19"></line>
          </svg>
        </div>
        <h3>Any Agent Runtime</h3>
        <p>
          Use Claude Code for coding, Codex for research, OpenHands for
          ops&mdash;or plug in your own runtime. Mix and match per role.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="architecture">
    <h2 class="section-title">How It Works</h2>

    <div class="arch-overview">
      <a href="https://strawhub.dev" target="_blank" rel="noopener" class="arch-node arch-link">
        <div class="arch-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          </svg>
        </div>
        <h3>StrawHub <span class="external-arrow">&nearr;</span></h3>
        <span>Skills, roles, agents &amp; memory</span>
      </a>

      <div class="arch-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-branches">
          <div class="connector-branch"></div>
          <div class="connector-branch"></div>
          <div class="connector-branch"></div>
        </div>
      </div>

      <div class="arch-sessions">
        <div class="session-card">
          <div class="session-header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"></polyline>
              <line x1="12" y1="19" x2="20" y2="19"></line>
            </svg>
            <span class="session-label">strawpot start</span>
          </div>
          <h3>Engineering</h3>
          <div class="session-agents">
            <span class="agent-tag">Lead</span>
            <span class="agent-tag">Coder</span>
            <span class="agent-tag">Tester</span>
          </div>
        </div>

        <div class="session-card">
          <div class="session-header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"></polyline>
              <line x1="12" y1="19" x2="20" y2="19"></line>
            </svg>
            <span class="session-label">strawpot start</span>
          </div>
          <h3>Research</h3>
          <div class="session-agents">
            <span class="agent-tag">Analyst</span>
            <span class="agent-tag">Writer</span>
            <span class="agent-tag">Reviewer</span>
          </div>
        </div>

        <div class="session-card">
          <div class="session-header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"></polyline>
              <line x1="12" y1="19" x2="20" y2="19"></line>
            </svg>
            <span class="session-label">strawpot start</span>
          </div>
          <h3>Marketing</h3>
          <div class="session-agents">
            <span class="agent-tag">Strategist</span>
            <span class="agent-tag">Copywriter</span>
            <span class="agent-tag">Designer</span>
          </div>
        </div>
      </div>
    </div>

    <div class="arch-steps">
      <ol>
        <li>Pull roles and skills from <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a> &mdash; or define your own</li>
        <li>Run <code>strawpot start</code> &mdash; each session gets an isolated workspace</li>
        <li>Agents delegate sub-tasks &mdash; StrawPot resolves roles and spawns sub-agents</li>
        <li>On exit, cleans up everything automatically</li>
      </ol>
    </div>
  </section>

  <!-- ===== STRAWHUB ===== -->
  <section class="strawhub">
    <div class="strawhub-inner">
      <div class="strawhub-text">
        <h2 class="section-title" style="text-align:left">
          Browse skills, roles, agents &amp; more on
          <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a>
        </h2>
        <p class="strawhub-desc">
          StrawHub is the public registry for reusable agent components&mdash;skills,
          roles, agent configs, and memory providers. Discover what the community
          has built, publish your own, and install straight from the CLI.
        </p>
        <div class="strawhub-commands">
          <code><span class="p">$</span> strawpot search <span class="s">"code-review"</span></code>
          <code><span class="p">$</span> strawpot install <span class="s">code-review</span></code>
        </div>
        <a
          href="https://strawhub.dev"
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          Explore StrawHub &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SUBSCRIBE ===== -->
  <section class="subscribe">
    <h2 class="section-title">Stay in the loop</h2>
    <p class="subscribe-desc">
      Get updates on new releases, features, and community highlights. No spam.
    </p>
    <form
      class="subscribe-form"
      id="subscribe-form"
      action="https://buttondown.com/api/emails/embed-subscribe/strawpot"
      method="post"
      target="bd-iframe"
    >
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        aria-label="Email address"
      />
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>
    <iframe name="bd-iframe" id="bd-iframe" style="display:none" aria-hidden="true"></iframe>
    <p class="subscribe-msg" id="subscribe-msg"></p>
    <p class="subscribe-note">
      Powered by <a href="https://buttondown.com" target="_blank" rel="noopener">Buttondown</a>
    </p>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <nav class="footer-links">
      <a href="https://github.com/strawpot/strawpot" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://strawhub.dev" target="_blank" rel="noopener">StrawHub</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://pypi.org/project/strawpot/" target="_blank" rel="noopener">PyPI</a>
      <span class="footer-sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/strawpot/strawpot/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
    </nav>
    <p class="footer-credit">Built by the StrawPot contributors.</p>
  </footer>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 4rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    background: radial-gradient(
      ellipse at center,
      rgba(232, 185, 49, 0.12) 0%,
      rgba(232, 185, 49, 0.04) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border) 50%,
      transparent 100%
    );
  }

  .hero-inner {
    max-width: var(--max-width);
    position: relative;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0s both;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #fff 0%, var(--color-straw-light) 30%, var(--color-straw) 70%, var(--color-straw-dark) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.2rem, 3vw, 1.75rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s ease-out 0.15s both;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease-out 0.25s both;
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.6rem 0.75rem 0.6rem 1.25rem;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0.35s both;
  }

  .hero-cmd {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .hero-cmd .p {
    color: var(--color-green);
    user-select: none;
  }

  .hero-copy {
    position: static;
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 0.5s both;
  }

  .hero-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 640px;
    margin: 2rem auto 0;
    animation: fadeInUp 0.6s ease-out 0.65s both;
  }

  .hero-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1.25rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: transform 0.2s, border-color 0.2s;
    color: var(--color-text);
  }

  .hero-link:hover {
    transform: translateY(-3px);
    color: var(--color-text);
  }

  .hero-link--discord:hover {
    border-color: #5865f2;
  }

  .hero-link--github:hover {
    border-color: #8b949e;
  }

  .hero-link--strawhub:hover {
    border-color: var(--color-straw);
  }

  .hero-link-label {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .hero-link-sub {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

